# Internal LiveKit websocket URL used by containers and the agent worker.
LIVEKIT_URL=ws://livekit-server:7880
# Public LiveKit URL returned to frontend clients by the token server.
LIVEKIT_PUBLIC_URL=ws://localhost:7880
# LiveKit API key used to sign and validate access tokens.
LIVEKIT_API_KEY=devkey
# LiveKit API secret paired with the API key above.
LIVEKIT_API_SECRET=secret

# Port exposed by the token server.
TOKEN_SERVER_PORT=8080
# Lifetime of generated client tokens in minutes.
TOKEN_TTL_MINUTES=60
# Comma-separated frontend origins allowed to call the token server.
TOKEN_CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Registered LiveKit agent name for dispatch.
AGENT_NAME=nusuk-agent
# System prompt fallback (nusuk_rag provider loads from RAG_VOICE_SECTIONS in agent/prompts/prompts.json).
AGENT_SYSTEM_PROMPT=
# Optional override for the system-prompt file path. Defaults to
# <agent_dir>/system_prompt_rag.txt and self-heals (regenerates from
# prompts.voice_prompt.RAG_VOICE_PROMPT) if the file is missing. Only set
# this when pointing at a non-standard layout.
# AGENT_SYSTEM_PROMPT_FILE=
# Spoken greeting the agent says after joining the room.
AGENT_GREETING=مرحبا، أنا مساعدك الصوتي. كيف أقدر أساعدك؟
# Deprecated compatibility flag. The current agent enables turn detection
# automatically when the dependency is installed in the worker image.
AGENT_USE_TURN_DETECTOR=false
# Silero VAD activation threshold.
AGENT_VAD_ACTIVATION_THRESHOLD=0.5
# Allow the user to interrupt the assistant while it is speaking.
AGENT_ALLOW_INTERRUPTIONS=true
# Drop buffered input audio when interruptions are disabled.
AGENT_DISCARD_AUDIO_IF_UNINTERRUPTIBLE=true
# Minimum speech duration in seconds to count as an interruption.
AGENT_MIN_INTERRUPTION_DURATION=0.5
# Minimum words needed before STT-based interruption is accepted.
# 1 filters coughs / mic bumps; a 0.5s "stop!" still interrupts via min_duration.
AGENT_MIN_INTERRUPTION_WORDS=1
# Minimum silence delay before ending the user's turn. With preemptive TTS
# already firing during this window, dropping from 0.5 to 0.3 shaves
# perceived turn-end without bad-UX cost (wasted speculation = compute only).
AGENT_MIN_ENDPOINTING_DELAY=0.3
# Maximum wait before LiveKit forces turn completion. 2s is the conversational
# cap for short Q&A; 5s of dead air is the worst-feeling failure mode for
# Arabic where the turn detector gives no semantic signal.
AGENT_MAX_ENDPOINTING_DELAY=2.0
# How long to wait before treating an interruption as false.
AGENT_FALSE_INTERRUPTION_TIMEOUT=2.0
# Resume assistant speech automatically after a false interruption.
AGENT_RESUME_FALSE_INTERRUPTION=true
# Extra speech delay guard before interruption logic triggers.
AGENT_MIN_CONSECUTIVE_SPEECH_DELAY=0.0
# Align emitted assistant transcripts to the timing of TTS audio.
AGENT_USE_TTS_ALIGNED_TRANSCRIPT=false
# Link the agent to a specific participant identity instead of the first participant.
AGENT_PARTICIPANT_IDENTITY=
# Close the session when the linked participant disconnects.
AGENT_CLOSE_ON_DISCONNECT=true
# Delete the room when the session closes.
AGENT_DELETE_ROOM_ON_CLOSE=false
# Self-hosted noise cancellation via DeepFilterNet3 (Apache-2.0). Off by
# default — enabling pulls PyTorch into the running process and adds
# ~12 ms latency per audio frame. Pre-install requires `deepfilternet`
# from requirements.txt. See agent/plugins/denoiser.py.
AGENT_NOISE_CANCELLATION=false

# Maximum concurrent rooms per worker process (controls load_fnc ceiling).
AGENT_MAX_JOBS_PER_WORKER=10
# Port for the Prometheus /metrics endpoint on the agent container.
AGENT_METRICS_PORT=9090

# ASR transcription service base URL.
CUSTOM_STT_URL=http://host.docker.internal:8100
# STT provider type: local_api, openai, or nusuk.
CUSTOM_STT_PROVIDER=local_api
# ASR model name when the provider uses one.
CUSTOM_STT_MODEL=asr_ctc
# Bearer token used when the STT API requires Authorization.
CUSTOM_STT_ACCESS_TOKEN=51132b7a725e8ddb196c581b3e7035f9
# Language hint sent to ASR.
CUSTOM_STT_LANGUAGE=ar
# ASR request timeout in seconds.
CUSTOM_STT_TIMEOUT_SECONDS=30
# Target sample rate used when resampling audio before ASR.
CUSTOM_STT_TARGET_SAMPLE_RATE=16000

# Base URL for the LLM API.
CUSTOM_LLM_URL=https://api.groq.com/openai/v1
# LLM provider type: openai or nusuk.
CUSTOM_LLM_PROVIDER=openai
# LLM model name when the provider uses one.
CUSTOM_LLM_MODEL=qwen/qwen3-32b
# Bearer token used when the LLM API requires Authorization, such as Groq.
CUSTOM_LLM_ACCESS_TOKEN=
# Language hint sent to the LLM service when supported.
CUSTOM_LLM_LANGUAGE=ar
# Ask the LLM service to include metadata when supported.
CUSTOM_LLM_INCLUDE_METADATA=true
# Nusuk tool name used for retrieval.
CUSTOM_LLM_TOOL=Knowledge
# user_id sent in the Nusuk /auth/token request body. Defaults to client_id.
CUSTOM_LLM_AUTH_USER_ID=
# Sampling temperature for the LLM.
CUSTOM_LLM_TEMPERATURE=0.2
# Maximum generated tokens per response.
CUSTOM_LLM_MAX_TOKENS=1200
# LLM request timeout in seconds.
CUSTOM_LLM_TIMEOUT_SECONDS=60

# TTS synthesis endpoint.
CUSTOM_TTS_URL=http://host.docker.internal:8110
# TTS provider type: local_api or generic.
CUSTOM_TTS_PROVIDER=local_api
# Bearer token used when the TTS API requires Authorization.
CUSTOM_TTS_ACCESS_TOKEN=
# TTS model name passed to the endpoint.
CUSTOM_TTS_MODEL=placeholder
# Voice name requested from the TTS service.
CUSTOM_TTS_VOICE=default
# Sample rate expected from the TTS output stream.
CUSTOM_TTS_SAMPLE_RATE=24000
# Number of audio channels expected from TTS output.
CUSTOM_TTS_NUM_CHANNELS=1
# Response format requested from TTS, usually wav or pcm.
CUSTOM_TTS_AUDIO_FORMAT=wav
# TTS request timeout in seconds.
CUSTOM_TTS_TIMEOUT_SECONDS=60

# Demo frontend (optional, used with: docker compose --profile demo up --build)
# The demo frontend reads LIVEKIT_API_KEY, LIVEKIT_API_SECRET, LIVEKIT_PUBLIC_URL,
# and AGENT_NAME from this file via docker-compose environment mapping.
# No additional variables needed. Open http://localhost:3000 after starting.

# Observability stack (optional, used with: docker compose --profile observability up)
# Prometheus UI host port.
PROMETHEUS_PORT=9091
# Grafana UI host port. Default Grafana login: admin / $GRAFANA_ADMIN_PASSWORD.
GRAFANA_PORT=3001
# Grafana admin password.
GRAFANA_ADMIN_PASSWORD=admin

# ──────────────────────────────────────────────────────────────────────────
# TEMP — local RAG adapter (agent/plugins/rag/)
# Drop these env vars and switch CUSTOM_LLM_PROVIDER back to `nusuk` once
# Nusuk /chat/stream is fixed upstream. See agent/plugins/rag/README.md.
# ──────────────────────────────────────────────────────────────────────────
# Set CUSTOM_LLM_PROVIDER=nusuk_rag to use the local RAG path (overrides any
# value set earlier in this file).
#CUSTOM_LLM_PROVIDER=nusuk_rag
# Number of top-reranked docs fused into the system prompt per turn.
CUSTOM_LLM_RAG_TOP_K=12
# Milvus. For local dev, run on the host: kubectl port-forward -n nlp-rag svc/milvus 19530:19530
# Use host.docker.internal so the agent container reaches the Mac's port-forward.
MILVUS_HOST=http://host.docker.internal
MILVUS_PORT=19530
MILVUS_COLLECTION=unified_nusuk_collection4
MILVUS_TOKEN=root:Milvus
# Embedding + reranker are public — no port-forward needed.
EMBEDDING_SERVICE_URL=https://embed.llmtests.org/v1/embeddings
RERANK_SERVICE_URL=https://ranker.llmtests.org/score
