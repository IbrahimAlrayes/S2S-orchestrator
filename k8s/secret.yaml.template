# ============================================================
# SECRET TEMPLATE — do NOT commit secret.yaml with real values.
# Copy this file to k8s/secret.yaml, fill in every placeholder,
# then apply:  kubectl apply -f k8s/secret.yaml
#
# k8s/secret.yaml is listed in .gitignore.
# ============================================================
apiVersion: v1
kind: Secret
metadata:
  name: s2s-secrets
  namespace: elm-s2s
type: Opaque
stringData:

  # ----------------------------------------------------------
  # LiveKit credentials
  # The API key and secret MUST match the keys block in livekit.yaml below.
  # ----------------------------------------------------------
  LIVEKIT_API_KEY: "changeme-api-key"
  LIVEKIT_API_SECRET: "changeme-api-secret"

  # Public WebSocket URL that browser clients use to reach LiveKit.
  # Fill this in AFTER the livekit-server LoadBalancer gets its external IP:
  #   kubectl get svc livekit-server -n elm-s2s
  # Then set:  wss://<EXTERNAL_IP>:7880
  LIVEKIT_PUBLIC_URL: "wss://REPLACE_WITH_LIVEKIT_LB_IP:7880"

  # ----------------------------------------------------------
  # LiveKit server config (stored as a Secret because it contains API keys)
  # Update the `keys` block to match LIVEKIT_API_KEY / LIVEKIT_API_SECRET above.
  # ----------------------------------------------------------
  livekit.yaml: |
    port: 7880

    rtc:
      tcp_port: 7881
      port_range_start: 50000
      port_range_end: 50020
      # use_external_ip: true — LiveKit queries GCE instance metadata to discover
      # the node's external IP and advertises it as ICE candidates for UDP media.
      # If nodes have no external IP (Cloud NAT only), set this to false and
      # set node_ip to the UDP LoadBalancer external IP after first deploy.
      use_external_ip: true

    redis:
      address: redis:6379

    keys:
      changeme-api-key: changeme-api-secret

    prometheus_port: 6789

  # ----------------------------------------------------------
  # STT service
  # Service runs in the asr-serving namespace on the same cluster.
  # Use internal cluster DNS — no external hop, stays on private VPC.
  # Pattern: http://<k8s-service-name>.asr-serving.svc.cluster.local:<port>
  # ----------------------------------------------------------
  CUSTOM_STT_URL: "http://REPLACE_WITH_ASR_SERVICE.asr-serving.svc.cluster.local:REPLACE_PORT"
  CUSTOM_STT_ACCESS_TOKEN: ""

  # ----------------------------------------------------------
  # LLM service
  # Service runs in the nlp-rag namespace on the same cluster.
  # Pattern: http://<k8s-service-name>.nlp-rag.svc.cluster.local:<port>
  # ----------------------------------------------------------
  CUSTOM_LLM_URL: "http://REPLACE_WITH_LLM_SERVICE.nlp-rag.svc.cluster.local:REPLACE_PORT"
  CUSTOM_LLM_ACCESS_TOKEN: ""
  CUSTOM_LLM_CLIENT_ID: ""
  CUSTOM_LLM_CLIENT_SECRET: ""

  # ----------------------------------------------------------
  # TTS service
  # Service runs in the elm-tts namespace on the same cluster.
  # Pattern: http://<k8s-service-name>.elm-tts.svc.cluster.local:<port>
  # ----------------------------------------------------------
  CUSTOM_TTS_URL: "http://REPLACE_WITH_TTS_SERVICE.elm-tts.svc.cluster.local:REPLACE_PORT"
  CUSTOM_TTS_ACCESS_TOKEN: ""

  # ----------------------------------------------------------
  # Milvus authentication
  # Used only when CUSTOM_LLM_PROVIDER=nusuk_rag (local-RAG path).
  # Same value the production nlp-rag-app uses for the shared Milvus instance.
  # Default for unauth'd dev/test deployments: "root:Milvus"
  # ----------------------------------------------------------
  MILVUS_TOKEN: "root:Milvus"

  # ----------------------------------------------------------
  # Token server — comma-separated allowed CORS origins.
  # Add the demo frontend domain once it is known.
  # ----------------------------------------------------------
  TOKEN_CORS_ORIGINS: "https://s2s-dev.nusukai.com"

  # ----------------------------------------------------------
  # Grafana (only needed if the observability profile is deployed)
  # ----------------------------------------------------------
  GRAFANA_ADMIN_PASSWORD: "changeme-grafana-password"
